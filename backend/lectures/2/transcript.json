{
  "lecture_id": 2,
  "audio_filename": "audio.m4a",
  "stt_audio_filename": "audio.16k_mono.wav",
  "model": "small",
  "language": "ko",
  "duration_sec": 790.82525,
  "num_segments": 217,
  "segments": [
    {
      "start": 0.0,
      "end": 3.2,
      "text": "오늘 저희가 함께 깊게 파고 들어 볼 자료는요"
    },
    {
      "start": 3.2,
      "end": 7.48,
      "text": "바로 웹 RTC 기술에 대한 대학 강의 자조들입니다"
    },
    {
      "start": 7.48,
      "end": 11.56,
      "text": "자료들에 보내주신 걸 보니 아마 그런 게 궁금하셨던 것 같아요"
    },
    {
      "start": 11.56,
      "end": 14.08,
      "text": "어떻게 별도 프로그램 설치 하나 없이"
    },
    {
      "start": 14.08,
      "end": 16.84,
      "text": "그냥 링크만 딱 누르면 화상 회의가 되고"
    },
    {
      "start": 16.84,
      "end": 19.12,
      "text": "라이브 방송을 볼 수 있는 걸까?"
    },
    {
      "start": 19.12,
      "end": 20.16,
      "text": "네 맞습니다"
    },
    {
      "start": 20.16,
      "end": 23.0,
      "text": "바로 이 웹 RTC라는 기술 덕분이죠"
    },
    {
      "start": 23.0,
      "end": 24.88,
      "text": "이번 시간에는 이 기술이"
    },
    {
      "start": 24.88,
      "end": 28.44,
      "text": "음 정확히 뭔지 또 어떤 원리로 작동하는지"
    },
    {
      "start": 28.44,
      "end": 33.44,
      "text": "그리고 우리 생활을 어떻게 바꾸고 있는지 그 핵심을 한번 제대로 알아보겠습니다."
    },
    {
      "start": 33.44,
      "end": 38.54,
      "text": "네, 외발TC 그니까 웹 리얼타임 커뮤니케이션의 약자인데요."
    },
    {
      "start": 38.54,
      "end": 41.68,
      "text": "이제는 뭐 우리한테 거의 공기 같은 기술이죠."
    },
    {
      "start": 41.68,
      "end": 45.58,
      "text": "별도의 프로그인 없이 그냥 순수하게 웹 자체의 힘만으로"
    },
    {
      "start": 45.58,
      "end": 49.18,
      "text": "실시간 소통을 가능하게 만든 오픈소스 프로젝트고"
    },
    {
      "start": 49.18,
      "end": 51.28,
      "text": "또 국제 웹 표준입니다."
    },
    {
      "start": 51.28,
      "end": 55.99,
      "text": "자료에 첨부된 다이어그램을 보시면 아주 중요한 특징이 하나 보이는데요."
    },
    {
      "start": 55.99,
      "end": 59.95,
      "text": "두 사용자의 브라우저가 어떤 중앙 서버를 거치지 않고요."
    },
    {
      "start": 59.95,
      "end": 64.85,
      "text": "마치 옆집에 놀러 가듯 서로 직접 데이터를 주고받는 모습이 그려져 있어요."
    },
    {
      "start": 64.85,
      "end": 71.25,
      "text": "이 P2P, 즉, P2P 방식만으로 웹 RTC의 심장이라고 할 수 있습니다."
    },
    {
      "start": 71.25,
      "end": 75.69,
      "text": "P2P, 개인과 개인이 직접 연결된다는 거군요."
    },
    {
      "start": 75.69,
      "end": 80.69,
      "text": "그럼 제 컴퓨터랑 상대방 컴퓨터가 인터넷이라는 이 넓은 세상에서"
    },
    {
      "start": 80.69,
      "end": 84.45,
      "text": "서로 직통전화를 거는 것 같은 그런 개념이겠네요."
    },
    {
      "start": 84.45,
      "end": 86.91,
      "text": "근데 자료에서 계속 강조하는 게"
    },
    {
      "start": 86.91,
      "end": 90.77,
      "text": "NAT라는 장애물을 꼭 넘어야 한다고 하더라고요."
    },
    {
      "start": 90.77,
      "end": 93.47,
      "text": "사실 우리 대부분은 집이나 사무실에서"
    },
    {
      "start": 93.47,
      "end": 98.17,
      "text": "인터넷 공유기, 그러니까 NAT 환경 안에서 인터넷을 쓰잖아요."
    },
    {
      "start": 98.17,
      "end": 101.05,
      "text": "이게 왜 P2P 연결에 문제라 되는 건가요?"
    },
    {
      "start": 101.05,
      "end": 103.65,
      "text": "아, 그거 정말 핵심적인 질문입니다."
    },
    {
      "start": 103.65,
      "end": 105.97,
      "text": "그 NAT에 주된 역할 중 하나가"
    },
    {
      "start": 105.97,
      "end": 108.17,
      "text": "일종의 방화벽 기능이거든요."
    },
    {
      "start": 108.17,
      "end": 111.29,
      "text": "외부 인터넷에서 우리 집 컴퓨터의 내부 IP 주소를"
    },
    {
      "start": 111.29,
      "end": 113.96,
      "text": "직접 볼 수 없게 막아주는 거죠."
    },
    {
      "start": 113.96,
      "end": 118.44,
      "text": "덕분에 보안은 좋아지는데 이게 P2P 통신에는 걸림돌이 됩니다."
    },
    {
      "start": 118.44,
      "end": 122.26,
      "text": "그러니까 상대방 브라울저가 저랑 통신하고 싶어도"
    },
    {
      "start": 122.26,
      "end": 127.72,
      "text": "저희 집 아파트 주소, 즉 공인 IP는 알지만 정확히 몇 동 몇 토"
    },
    {
      "start": 127.72,
      "end": 132.44,
      "text": "즉 내부 IP인지를 모르니까 찾아올 방법이 없는 상황이 벌어지는 겁니다."
    },
    {
      "start": 132.44,
      "end": 136.2,
      "text": "아하, 비유가 그냥 확 와닿네요."
    },
    {
      "start": 136.2,
      "end": 141.32,
      "text": "인터넷이라는 거대한 도시에서 저희 아파트 정문까지는 어떻게 찾아왔는데"
    },
    {
      "start": 141.32,
      "end": 144.32,
      "text": "막상 들어와 보니까 수많은 집들 중에서"
    },
    {
      "start": 144.32,
      "end": 148.8,
      "text": "대체 어느 집 현관문을 두드려야 할지 몰라서 헤매는 그런 상황이군요."
    },
    {
      "start": 148.8,
      "end": 150.84,
      "text": "네 그 비유가 완벽합니다."
    },
    {
      "start": 150.84,
      "end": 153.92,
      "text": "그리고 외발티 씨는 이 문제를 해결하기 위해서"
    },
    {
      "start": 153.92,
      "end": 156.48,
      "text": "아주 영리한 해결사들을 고용합니다."
    },
    {
      "start": 156.48,
      "end": 162.1,
      "text": "자료에 계속 등장하는 S-T-U-N-TURN-IC가 바로 그 주인공들이죠."
    },
    {
      "start": 162.1,
      "end": 164.74,
      "text": "S-T-U-N-TURN-IC"
    },
    {
      "start": 164.74,
      "end": 168.34,
      "text": "이름들이 공 무슨 첫보 영화에 나오는 작전명 같아요."
    },
    {
      "start": 168.34,
      "end": 174.54,
      "text": "이 세 가지가 어떻게 협력해서 그 복잡한 NAT 문제를 해결하는지 정말 궁금한데요."
    },
    {
      "start": 174.54,
      "end": 176.7,
      "text": "ST-1부터 시작해볼까요?"
    },
    {
      "start": 176.7,
      "end": 180.66,
      "text": "자료 그림을 보니까 FEAR-A가 ST-1 서버한테"
    },
    {
      "start": 180.66,
      "end": 182.94,
      "text": "후에 마이 이렇게 묻고 있던데요."
    },
    {
      "start": 182.94,
      "end": 186.7,
      "text": "네 맞아요. ST-1 서버의 역할은 생각보다 간단합니다."
    },
    {
      "start": 186.7,
      "end": 190.78,
      "text": "제 컴퓨터가 ST-1 서버한테 안영하고 말을 걸면요"
    },
    {
      "start": 190.78,
      "end": 193.62,
      "text": "ST-1 서버는 그 메시지를 딱 받고 나서"
    },
    {
      "start": 193.62,
      "end": 198.22,
      "text": "어? 니가 본연 메시지는 인터넷 해장에서 바로 이 주소"
    },
    {
      "start": 198.22,
      "end": 203.84,
      "text": "즉, 공인 IP와 포트로 나한테 도착했어? 라고 답장을 보내주는 거예요."
    },
    {
      "start": 203.84,
      "end": 208.4,
      "text": "다시 말해, NAT라는 아파트 단지 안에 숨어있는 제 컴퓨터가"
    },
    {
      "start": 208.4,
      "end": 214.64,
      "text": "바깥 세상에서는 어떤 주소로 보이는지 그 공개된 주소를 알려주는 안내원인 셈이죠."
    },
    {
      "start": 214.64,
      "end": 220.92,
      "text": "아, 네비게이션이 당신의 현재 위치는 여기입니다. 하고 좌표 찍어주는 거랑 비슷하네요."
    },
    {
      "start": 220.92,
      "end": 225.18,
      "text": "그럼 그렇게 알아낸 제 공개 주소를 상대방한테 알려주면"
    },
    {
      "start": 225.18,
      "end": 229.06,
      "text": "상대방이 그 주소로 바로 찾아올 수 있게 되는 거고요."
    },
    {
      "start": 229.06,
      "end": 232.14,
      "text": "근데 수툰만으로 해결이 안 되는 경우도 있나요?"
    },
    {
      "start": 232.14,
      "end": 237.26,
      "text": "자료를 보니까 뭐 대칭형 네트 같은 골치 아픈 케이스가 있던데요?"
    },
    {
      "start": 237.26,
      "end": 240.94,
      "text": "네, 바로 그 지점 때문에 턴이 필요합니다."
    },
    {
      "start": 240.94,
      "end": 244.06,
      "text": "제가 예전에 외발티시 앱을 개발할 때"
    },
    {
      "start": 244.06,
      "end": 247.3,
      "text": "정말 이상하게 특정 회사 네트워크에만 들어가면"
    },
    {
      "start": 247.3,
      "end": 251.2,
      "text": "연결이 안 돼서 며칠 밤을 샌 적이 있거든요."
    },
    {
      "start": 251.2,
      "end": 256.25,
      "text": "알고 보니 원인이 바로 그 대칭형 네트 때문이었어요."
    },
    {
      "start": 256.25,
      "end": 261.15,
      "text": "비유하자면 아주 까다로운 경비원이 지키는 아파트 단지 같은 거예요"
    },
    {
      "start": 261.15,
      "end": 263.91,
      "text": "제가 스튼서버라는 특정 손님한테"
    },
    {
      "start": 263.91,
      "end": 268.0,
      "text": "100일동 1,203호로 오세요 라고 초대장을 보냈다고 쳐보죠"
    },
    {
      "start": 268.0,
      "end": 272.52,
      "text": "그럼 이 까다로운 경비원은 초대장에 적힌 바로 그 스튼서버가 아니면"
    },
    {
      "start": 272.52,
      "end": 277.48,
      "text": "제 친구 즉 피어 비가 똑같이 100일동 1,203호로 찾아와도"
    },
    {
      "start": 277.48,
      "end": 281.3,
      "text": "당신은 초대받지 않았습니다 하면서 문을 절대 안 열어주는 겁니다"
    },
    {
      "start": 281.3,
      "end": 283.82,
      "text": "스튼으로 알아낸 주소가 쓸모 없어지는 거죠"
    },
    {
      "start": 283.82,
      "end": 286.5,
      "text": "와 보완이 정말 철저하네요"
    },
    {
      "start": 286.5,
      "end": 290.58,
      "text": "그럼 이럴 때는 P2P 직접 연결은 그냥 포기해야 하는 건가요?"
    },
    {
      "start": 290.58,
      "end": 294.2,
      "text": "이때 최후의 수단으로 등장하는 게 바로 턴 서버입니다"
    },
    {
      "start": 294.2,
      "end": 298.36,
      "text": "턴 서버는 이름 그대로 중계 서버 역할을 자초하는 건데요"
    },
    {
      "start": 298.36,
      "end": 300.64,
      "text": "저와 상대방이 직접 통신하는 대신"
    },
    {
      "start": 300.64,
      "end": 305.43,
      "text": "둘 다 턴 서버에 접속해서 모든 데이터를 그 서버를 통해 주고받는 거예요"
    },
    {
      "start": 305.43,
      "end": 309.47,
      "text": "제가 보낸 영상 데이터를 턴 서버가 받아서 상대방한테 전달해주고"
    },
    {
      "start": 309.47,
      "end": 312.55,
      "text": "또 상대방의 음성 데이터를 받아서 저한테 전달해주고요"
    },
    {
      "start": 312.55,
      "end": 320.67,
      "text": "잠깐만요 그럼 턴 서버를 쓴다는건 결국 모든 데이터가 다시 중앙서버를 거쳐간다는 뜻이잖아요"
    },
    {
      "start": 320.67,
      "end": 326.83,
      "text": "그건 P2P의 가장 큰 장점인 탈중앙화된 직접 연결을 포기하는 셈인데"
    },
    {
      "start": 326.83,
      "end": 329.03,
      "text": "이건 중 후퇴하는 것 아닌가요?"
    },
    {
      "start": 329.03,
      "end": 332.43,
      "text": "예를 들면 뭐 쥬음이나 구글 미트 같은 회사들은"
    },
    {
      "start": 332.43,
      "end": 335.95,
      "text": "이 턴 서버 운영의 비용이 엄청나게 들 것 같은데요"
    },
    {
      "start": 335.95,
      "end": 337.8,
      "text": "네 정확히 보셨습니다"
    },
    {
      "start": 337.8,
      "end": 341.9,
      "text": "P2P 연결이 실패했을 때 일종의 플랜 빈 셈이죠"
    },
    {
      "start": 341.9,
      "end": 344.9,
      "text": "마지막인 대로 모든 트래픽이 서버를 거치니까"
    },
    {
      "start": 344.9,
      "end": 348.62,
      "text": "서버 유지 비용, 네트워크 대역복 비용이 상당합니다."
    },
    {
      "start": 348.62,
      "end": 350.78,
      "text": "그래서 대규모 서비스를 하는 회사들은"
    },
    {
      "start": 350.78,
      "end": 354.42,
      "text": "이 턴 서버 비용을 줄이는 게 굉장히 중요한 과제고요."
    },
    {
      "start": 354.42,
      "end": 357.84,
      "text": "하지만 P2P 연결 성공률이 100%가 아닌 이상"
    },
    {
      "start": 357.84,
      "end": 360.6,
      "text": "어떤 까다라운 네트워크 환경의 사용자라도"
    },
    {
      "start": 360.6,
      "end": 364.34,
      "text": "서비스에서 소외되지 않도록 보장해주는 최후의 보루"
    },
    {
      "start": 364.34,
      "end": 368.6,
      "text": "뭐랄까 보험 같은 존재로서 턴은 없어서는 안 됩니다."
    },
    {
      "start": 368.6,
      "end": 370.8,
      "text": "이상과 현실의 절충 아닌 셈이죠."
    },
    {
      "start": 370.8,
      "end": 372.0,
      "text": "알겠습니다."
    },
    {
      "start": 372.0,
      "end": 376.36,
      "text": "그럼 제 브라우저는 이제 스턴으로 알아낸 직접 연결 주소,"
    },
    {
      "start": 376.36,
      "end": 378.12,
      "text": "턴서버의 중개 주소,"
    },
    {
      "start": 378.12,
      "end": 383.4,
      "text": "뭐 심지어 내부 IP 주소까지 여러 개의 연결 후보를 갖게 되는 거군요."
    },
    {
      "start": 383.4,
      "end": 386.4,
      "text": "이렇게 선택지가 많으면 오히려 헷갈릴 것 같은데"
    },
    {
      "start": 386.4,
      "end": 392.04,
      "text": "이 중에서 어떤 경로가 가장 좋은지 어떻게 알고 똑똑하게 골라내는 거죠?"
    },
    {
      "start": 392.04,
      "end": 395.72,
      "text": "뭔가 이 모든 과정을 총괄 지휘하는 역할이 필요할 것 같은데요?"
    },
    {
      "start": 395.72,
      "end": 400.36,
      "text": "네, 바로 그 총괄 지휘관이 IC입니다."
    },
    {
      "start": 400.36,
      "end": 403.88,
      "text": "Interactive Connectivity Establishment 약자죠"
    },
    {
      "start": 403.88,
      "end": 406.68,
      "text": "ICN은 통신을 시작하기 전에요"
    },
    {
      "start": 406.68,
      "end": 411.35,
      "text": "연결 가능한 모든 경로 후보들을 수집해서 목록으로 쫙 만들어요"
    },
    {
      "start": 411.35,
      "end": 416.45,
      "text": "내부 IP, 스탄으로 얻은 공인 IP, 턴중계 주소까지 전부요"
    },
    {
      "start": 416.45,
      "end": 419.45,
      "text": "그리고 이 후보 목록을 상대방과 교환한 다음에"
    },
    {
      "start": 419.45,
      "end": 423.24,
      "text": "서로에게 PING을 보내는 것처럼 연결 테스트를 막해봅니다"
    },
    {
      "start": 423.24,
      "end": 426.44,
      "text": "그리고 그 중에서 가장 빠르고 효율적인 경로"
    },
    {
      "start": 426.44,
      "end": 429.68,
      "text": "그러니까 우선 순위가 가장 높은 경로를 찾아내서"
    },
    {
      "start": 429.68,
      "end": 431.92,
      "text": "최종 통신 채널로 확정하는 거죠"
    },
    {
      "start": 431.92,
      "end": 435.88,
      "text": "아 보통은 그게 P2P 직접 연결이겠군요"
    },
    {
      "start": 435.88,
      "end": 437.6,
      "text": "네 대부분은 그렇죠"
    },
    {
      "start": 437.6,
      "end": 439.72,
      "text": "가능한 모든 길을 탐색하고"
    },
    {
      "start": 439.72,
      "end": 441.44,
      "text": "가장 좋은 길을 찾아내는"
    },
    {
      "start": 441.44,
      "end": 443.8,
      "text": "아주 정교한 협상 과정이라고 보시면 됩니다"
    },
    {
      "start": 443.8,
      "end": 446.04,
      "text": "와 정말 체계적이네요"
    },
    {
      "start": 446.04,
      "end": 449.64,
      "text": "이 복잡한 기술을 그럼 개발자들은 어떻게 활용할까요?"
    },
    {
      "start": 449.64,
      "end": 452.08,
      "text": "자료의 주요 자바스크립트 API가"
    },
    {
      "start": 452.08,
      "end": 454.16,
      "text": "세 가지 소개되어 있더라고요"
    },
    {
      "start": 454.16,
      "end": 458.44,
      "text": "GetUserMedia, RTC Peer Connection, RTC 데이터 채널"
    },
    {
      "start": 458.44,
      "end": 464.4,
      "text": "외발티쉬의 위대함은 이 모든 복잡한 과정을 개발자가 아주 쉽게 사용할 수 있도록"
    },
    {
      "start": 464.4,
      "end": 467.31,
      "text": "표조나된 API로 제공한다는 점에 있어요."
    },
    {
      "start": 467.31,
      "end": 469.99,
      "text": "GetUserMedia는 가장 첫 단계인데요."
    },
    {
      "start": 469.99,
      "end": 473.85,
      "text": "혹시 화상회의 사이트에 처음 접속했을 때 브라우저 위에"
    },
    {
      "start": 473.85,
      "end": 477.47,
      "text": "이 사이트에서 카메라와 마이크 사용을 허용하시겠습니까?"
    },
    {
      "start": 477.47,
      "end": 479.23,
      "text": "하는 팝업창 뜨는 거 보셨죠?"
    },
    {
      "start": 479.23,
      "end": 480.35,
      "text": "바로 그 겁니다."
    },
    {
      "start": 480.35,
      "end": 482.39,
      "text": "아, 그 팝업창이요?"
    },
    {
      "start": 482.39,
      "end": 486.91,
      "text": "항상 모심코 허용을 눌렀는데 그게 GetUserMedia였군요."
    },
    {
      "start": 486.91,
      "end": 491.51,
      "text": "그럼 허용을 누르는 순간 제 카메라가 켜지고 화면에 제 얼굴이 나오기 시작하는 거고요."
    },
    {
      "start": 492.01,
      "end": 494.01,
      "text": "다음은 RTC FEAR 커넥션인데"
    },
    {
      "start": 494.31,
      "end": 497.71,
      "text": "이건 뭐 이름부터가 FEAR 연결이니까 이게 핵심이겠네요."
    },
    {
      "start": 497.91,
      "end": 500.41,
      "text": "커넥션이 바로 외발 T.C.의 심장보입니다."
    },
    {
      "start": 501.18,
      "end": 505.38,
      "text": "저희가 앞에서 길게 설명했던 IC 프레임워크를 작동시켜서"
    },
    {
      "start": 505.58,
      "end": 507.58,
      "text": "스턴, 턴 서버를 이용하고"
    },
    {
      "start": 507.88,
      "end": 512.98,
      "text": "상대방과 최적의 경로를 찾아내는 그 모든 과정이 이 객체 안에서 다 일어납니다."
    },
    {
      "start": 512.98,
      "end": 518.29,
      "text": "그뿐만 아니라 음성이나 영상을 어떤 형식으로 압축해서 보낼지"
    },
    {
      "start": 518.29,
      "end": 521.67,
      "text": "또 통신 내용을 안전하게 암호하는 기능"
    },
    {
      "start": 521.67,
      "end": 526.47,
      "text": "네터옥 그 상태가 나빠지면 화질을 설적 낮춰서라도 연결을 유지하는"
    },
    {
      "start": 526.47,
      "end": 528.17,
      "text": "그런 대역폭 관리까지"
    },
    {
      "start": 528.17,
      "end": 533.05,
      "text": "실제 통신에 필요한 모든 복잡한 작업을 얘가 다 알아서 처리해주는 거죠"
    },
    {
      "start": 533.05,
      "end": 535.31,
      "text": "거의 뭐 만능 해결사네요"
    },
    {
      "start": 535.31,
      "end": 538.35,
      "text": "마지막으로 RTC 데이터 채널은 뭔가요?"
    },
    {
      "start": 538.35,
      "end": 540.39,
      "text": "이름에 데이터가 들어가는데"
    },
    {
      "start": 540.39,
      "end": 544.09,
      "text": "영상이나 음성 말고 다른 것도 보낼 수 있다는 뜻인가요?"
    },
    {
      "start": 544.09,
      "end": 545.73,
      "text": "네, 정확합니다."
    },
    {
      "start": 545.73,
      "end": 549.33,
      "text": "외발티시가 처음엔 화상통신을 위해 만들어졌지만"
    },
    {
      "start": 549.33,
      "end": 552.81,
      "text": "사람들이 쓰다 보니 파일이나 채팅 메시지 같은"
    },
    {
      "start": 552.81,
      "end": 557.15,
      "text": "다른 데이터도 P2P로 직접 주고받고 싶다는 요구가 생긴 거예요."
    },
    {
      "start": 557.15,
      "end": 562.08,
      "text": "RTC 데이터 채널은 바로 그런 요구를 위해 만들어진 별도의 통로입니다."
    },
    {
      "start": 562.08,
      "end": 566.74,
      "text": "이걸 이용하면 파일, 채팅 메시지 아니면 온라인 협업툴에서"
    },
    {
      "start": 566.74,
      "end": 570.24,
      "text": "실시간으로 움직이는 다른 사람의 마우스 커서 위치,"
    },
    {
      "start": 570.24,
      "end": 573.84,
      "text": "게임 캐릭터의 좌표 데이터 같은 정말 어떤 데이터든"
    },
    {
      "start": 573.84,
      "end": 576.62,
      "text": "P2P로 직접 주고받을 수 있습니다."
    },
    {
      "start": 576.62,
      "end": 581.22,
      "text": "중앙서버를 안 거치니까 지연 시간이 극도로 짧다는 엄청한 장점이 있죠."
    },
    {
      "start": 581.22,
      "end": 585.82,
      "text": "이 기술이 단순히 화상 통화에만 쓰이는 게 아니라는 점이 정말 흥미롭습니다."
    },
    {
      "start": 585.82,
      "end": 589.42,
      "text": "자료에 나온 차트를 보니까 활용 분야가 정말 넓네요."
    },
    {
      "start": 589.42,
      "end": 593.72,
      "text": "특히 원격 드론 제어나 원격 공양 같은 예시가 눈에 띄는데요."
    },
    {
      "start": 593.72,
      "end": 599.62,
      "text": "이건 그냥 화면을 보는 걸 넘어서서 지연 시간이 거의 없어야만 의미가 있는 서비스잖아요."
    },
    {
      "start": 599.62,
      "end": 601.82,
      "text": "바로 그 점이 중요합니다."
    },
    {
      "start": 601.82,
      "end": 603.82,
      "text": "원격 공연을 예로 한번 들어볼까요?"
    },
    {
      "start": 603.82,
      "end": 608.34,
      "text": "0.1초에 지연만 있어도 합주가 불가능해지거든요."
    },
    {
      "start": 608.34,
      "end": 611.34,
      "text": "기존의 서버 클라이언트 방식 스트리밍은"
    },
    {
      "start": 611.34,
      "end": 614.34,
      "text": "보통 수초에 지연시간이 발생하기 때문에"
    },
    {
      "start": 614.34,
      "end": 617.34,
      "text": "이런 서비스는 상상하기 어려웠지요."
    },
    {
      "start": 617.34,
      "end": 620.34,
      "text": "하지만 외발티신은 P2P 직접 통신으로"
    },
    {
      "start": 620.34,
      "end": 623.34,
      "text": "이 지연시간을 수심 밀리초"
    },
    {
      "start": 623.34,
      "end": 627.67,
      "text": "그러니까 0.1초보다 훨씬 짧은 단위까지 줄여줍니다."
    },
    {
      "start": 627.67,
      "end": 632.83,
      "text": "이론적으로는 지구 반대편의 연주자와도 실시간 합주가 가능해지는 겁니다"
    },
    {
      "start": 632.83,
      "end": 635.91,
      "text": "와우 드론 제호도 마찬가지겠네요"
    },
    {
      "start": 635.91,
      "end": 639.09,
      "text": "조종 스틱을 움직이는 즉시 드론이 가능해야 하니까요"
    },
    {
      "start": 639.09,
      "end": 640.36,
      "text": "그렇죠"
    },
    {
      "start": 640.36,
      "end": 644.1,
      "text": "1대 다수 서비스로 라이브 커머스나 웹이너도 있던데"
    },
    {
      "start": 644.1,
      "end": 647.3,
      "text": "한 명의 진행자가 여러 명한테 방송을 쏘는 거잖아요"
    },
    {
      "start": 647.3,
      "end": 650.3,
      "text": "이건 기존의 라이브 스트리밍 기술이랑은 어떻게 다른 건가요?"
    },
    {
      "start": 650.3,
      "end": 651.78,
      "text": "좋은 질문입니다"
    },
    {
      "start": 651.78,
      "end": 655.54,
      "text": "기존 기술들은 보통 지원 시간이 몇 초씩 발생하지만"
    },
    {
      "start": 655.54,
      "end": 660.47,
      "text": "외발티시 기반 라이브 커머스는 시청자와의 상호작용이 훨씬 즉각적이에요."
    },
    {
      "start": 660.47,
      "end": 666.59,
      "text": "시청자가 채팅으로 질문을 올리면 진행자가 거의 실시간으로 보고 답변할 수 있죠."
    },
    {
      "start": 666.59,
      "end": 672.03,
      "text": "이런 짧은 지연시간, 즉 로우 레이턴 씨가 시청자의 몰입감을 높이고"
    },
    {
      "start": 672.03,
      "end": 675.35,
      "text": "결국 구매 전환율을 높이는 핵심 요소가 되는 겁니다."
    },
    {
      "start": 675.35,
      "end": 681.63,
      "text": "이처럼 다수대 다수 화상웨이부터 1대 다수라이브 방송, 1대1 원격 제어까지"
    },
    {
      "start": 681.63,
      "end": 688.87,
      "text": "이 모든 것이 별도 프로그램 설치 없이 웹브라우저 하나로 가능하다는 게 웹알티시가 가져온 혁신인 거죠."
    },
    {
      "start": 688.87,
      "end": 691.31,
      "text": "자 그럼 정리를 한번 해보죠."
    },
    {
      "start": 691.31,
      "end": 694.95,
      "text": "웹브라우저 안에서 실시간 통신을 가능하게 하는 기술,"
    },
    {
      "start": 694.95,
      "end": 700.7,
      "text": "웹알티시의 핵심은 중앙서버를 거치지 않는 P2P 직섭 연결렸습니다."
    },
    {
      "start": 700.7,
      "end": 706.18,
      "text": "그리고 우리 대부분이 사용하는 공유기, 네트라는 현실의 장벽을 넘기기 위해서"
    },
    {
      "start": 706.18,
      "end": 712.64,
      "text": "스튼, 턴, IC라는 첩보 작정 같은 기술들이 아주 유기적으로 협력하고 있었네요."
    },
    {
      "start": 712.64,
      "end": 715.7,
      "text": "이제 화상회의에 참여하거나 라이브 방송을 볼 때"
    },
    {
      "start": 715.7,
      "end": 720.14,
      "text": "화면 뒤에서 이런 놀라운 과정이 벌어지고 있다는 걸 떠올리게 될 것 같습니다."
    },
    {
      "start": 720.14,
      "end": 721.8,
      "text": "네, 맞습니다."
    },
    {
      "start": 721.8,
      "end": 726.64,
      "text": "외바이티시는 복잡하고 예측 불가능한 인터넷 네트워크 환경 속에서"
    },
    {
      "start": 726.64,
      "end": 730.68,
      "text": "어떻게든 두 사용자 간의 최적의 통신 경로를 찾아내는"
    },
    {
      "start": 730.68,
      "end": 733.47,
      "text": "아주 정교하고 강력한 시스템입니다."
    },
    {
      "start": 733.47,
      "end": 736.71,
      "text": "그리고 이 모든 것이 표준 API로 제공돼서"
    },
    {
      "start": 736.71,
      "end": 741.39,
      "text": "개발자들이 쉽게 확신적인 서비스를 만들 수 있는 토대를 마련했다는 점에서"
    },
    {
      "start": 741.39,
      "end": 744.45,
      "text": "웹생태계에 아주 큰 기여를 했다고 볼 수 있죠."
    },
    {
      "start": 744.45,
      "end": 749.13,
      "text": "근데 자료에서는 주로 사람과 사람 간의 소통을 위한 웹 알티시를 다뤘습니다."
    },
    {
      "start": 749.13,
      "end": 752.49,
      "text": "하지만 마지막으로 설명드렸던 RTC 데이터 채널이"
    },
    {
      "start": 752.49,
      "end": 755.61,
      "text": "어떤 형표의 데이터든 P2P로 직접 전송할 수 있다는 점을"
    },
    {
      "start": 755.61,
      "end": 757.52,
      "text": "한번 생각해보면 어떨까요?"
    },
    {
      "start": 757.52,
      "end": 759.24,
      "text": "만약 이 기술을 활용해서"
    },
    {
      "start": 759.24,
      "end": 762.92,
      "text": "전 세계 수많은 사용자들의 브라우저들을 직접 연결해서"
    },
    {
      "start": 762.92,
      "end": 765.4,
      "text": "거대한 분산 네트워크를 만든다면"
    },
    {
      "start": 765.4,
      "end": 769.8,
      "text": "중앙서버 없이도 작동하는 완전히 새로운 형태의 서비스가 가능해집니다."
    },
    {
      "start": 769.8,
      "end": 773.68,
      "text": "예를 들면, 중앙서버 없이 사용자들끼리 파일을 공유하고"
    },
    {
      "start": 773.68,
      "end": 776.74,
      "text": "문서를 편집하는 협업도구나, 소셜 미디어,"
    },
    {
      "start": 776.74,
      "end": 780.26,
      "text": "심지어는 전 세계 브라우저에 쉬고 있는 자원을 모아서"
    },
    {
      "start": 780.26,
      "end": 784.78,
      "text": "거대한 연산 작업을 처리하는 분산 컴퓨팅 프라퍸까지도 가능하지 않을까요?"
    },
    {
      "start": 784.78,
      "end": 789.4,
      "text": "앞으로 외발티시가 열어갈 이 탈중앙화된 외배미래를 상상해 보시는 것도"
    },
    {
      "start": 789.4,
      "end": 790.9,
      "text": "아주 흥미로운 일이 될 겁니다."
    }
  ],
